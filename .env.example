# ============================================================================
# Lead Magnet System In A Box (v1) - Environment Variables
# ============================================================================
# Copy this to .env and fill in your keys.
# NEVER commit .env to version control.
# ============================================================================

# Anthropic (Claude API) - Required for the writing pipeline
ANTHROPIC_API_KEY=

# Notion (optional - for publishing to Notion)
NOTION_API_KEY=
NOTION_PARENT_PAGE_ID=

# Google Gemini (optional - for AI infographic generation)
GEMINI_API_KEY=
